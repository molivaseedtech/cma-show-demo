# Server
PORT=4173
HOST=127.0.0.1
ADMIN_TOKEN=
CMA_TIMEZONE=America/New_York
# Set these to a mounted persistent volume when hosting online.
CMA_DATA_DIR=
CMA_UPLOAD_DIR=
CMA_DISCORD_INVITE_URL=
# Optional MapLibre/MapTiler/self-hosted style. The demo uses MapLibre demo tiles.
CMA_MAP_STYLE_URL=
# Give Carla Marie and Anthony separate passwords. Never commit real values.
CMA_CARLA_PASSWORD=
CMA_ANTHONY_PASSWORD=
# Long random value used to sign 12-hour login sessions.
SESSION_SECRET=

# Podcast system of record. Megaphone RSS works without API access.
PODCAST_PROVIDER=megaphone
MEGAPHONE_RSS_URL=https://feeds.megaphone.fm/GEMINIMEDIA5276993481
MEGAPHONE_PODCAST_ID=
# Megaphone API access is enterprise-only; leave blank unless enabled for CMA.
MEGAPHONE_API_TOKEN=

# Listener accounts and bot protection for episode comments.
# Use Cloudflare Turnstile production keys on the live domain. Local development
# automatically uses Cloudflare's official always-pass test keys.
LISTENER_SESSION_SECRET=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloud AI (server-side only)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# M4 on-device AI. whisper.cpp and Ollama are recommended.
LOCAL_WHISPER_BIN=
LOCAL_WHISPER_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=

# Optional Twitch VOD discovery
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CHANNEL_LOGIN=CarlaMarieandAnthony

# Optional source downloader for Twitch/YouTube URLs (for example yt-dlp)
LOCAL_MEDIA_DOWNLOADER=yt-dlp
